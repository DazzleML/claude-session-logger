{
  "$schema": "../hooks/schemas/session-logger.schema.json",
  "_comment": "MINIMAL preset: only the curated shell history channel. This covers both the 'minimal' and 'shell-history-only' use cases.",

  "routing": {
    "channels": {
      "shell":    {"file_prefix": ".shell_",    "enabled": true},
      "sesslog":  {"file_prefix": ".sesslog_",  "enabled": false},
      "tasks":    {"file_prefix": ".tasks_",    "enabled": false},
      "tools":    {"file_prefix": ".tools_",    "enabled": false},
      "convo":    {"file_prefix": ".convo_",    "enabled": false},
      "unknowns": {"file_prefix": ".unknowns_", "enabled": false}
    }
  }
}
